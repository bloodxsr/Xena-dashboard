# Fluxer OAuth for dashboard login
FLUXER_CLIENT_ID=
FLUXER_CLIENT_SECRET=
FLUXER_REDIRECT_URI=http://localhost:3000/oauth/callback
FLUXER_OAUTH_AUTHORIZE_URL=https://api.fluxer.app/oauth2/authorize
FLUXER_OAUTH_TOKEN_URL=https://api.fluxer.app/oauth2/token
FLUXER_API_BASE_URL=https://api.fluxer.app

# White-label branding for sale/deployment
DASHBOARD_BRAND_NAME=Fluxer Control

# Session signing
DASHBOARD_SESSION_SECRET=replace-with-min-32-char-random-secret
DASHBOARD_SESSION_TTL_SECONDS=28800

# Bot and DB access (for common guild checks and bot DM TOTP setup)
FLUXER_BOT_TOKEN=

# DB backend: postgres (recommended production) or sqlite (local fallback)
DASHBOARD_DB_DRIVER=postgres
BOT_DB_PATH=../bot_js/data/warnings.db

# PostgreSQL settings
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DATABASE=fluxer_dashboard
POSTGRES_POOL_MAX=10
POSTGRES_SSL_MODE=disabled

# Optional TOTP tuning (should match bot defaults)
TOTP_ISSUER=FluxerBot
TOTP_AUTH_WINDOW_DAYS=30
TOTP_CODE_DIGITS=6
TOTP_PERIOD_SECONDS=30
TOTP_VERIFY_WINDOW_STEPS=1
