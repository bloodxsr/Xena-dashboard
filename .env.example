# App base URL for login redirects and links
APP_BASE_URL=http://127.0.0.1:3000

# Fluxer OAuth2 endpoints
FLUXER_WEB_BASE=https://web.fluxer.app
FLUXER_API_BASE=https://api.fluxer.app
# Optional: explicit redirect URI (must be registered in Fluxer OAuth app)
# FLUXER_REDIRECT_URI=https://your-domain/auth/callback

# Fluxer OAuth2 application credentials
FLUXER_CLIENT_ID=your_fluxer_oauth_client_id
FLUXER_CLIENT_SECRET=your_fluxer_oauth_client_secret

# Optional: override default OAuth scopes
# FLUXER_OAUTH_SCOPE=identify guilds

# Optional: disable webpack disk cache if Windows file-lock ENOENT warnings appear
# NEXT_DISABLE_WEBPACK_CACHE=1

# Optional: require key parameter on /login?key=...
# FLUXER_DASHBOARD_KEY=replace_with_long_random_key

# Optional: restrict dashboard to these guild IDs (comma-separated)
# FLUXER_ALLOWED_GUILD_IDS=123456789012345678,987654321098765432

# Session secret for signing cookies
# Use a long random value in production.
SESSION_SECRET=replace_with_long_random_hex_or_base64_secret


# Optional: SQLite DB path (default: ../bot/warnings.db)
# DATABASE_PATH=../bot/warnings.db

# Bot token used for shared-guild intersection in staff dashboard filtering
FLUXER_BOT_TOKEN=your_fluxer_bot_token
# BOT_TOKEN=your_fluxer_bot_token
